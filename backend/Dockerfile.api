FROM python:3.11-slim

WORKDIR /app

COPY pyproject.toml ./
COPY qdra ./qdra
COPY scripts ./scripts
COPY docker ./docker
RUN pip install --no-cache-dir -e .

ENV PYTHONPATH=/app/qdra
ENV PYTHONUNBUFFERED=1

EXPOSE 8000

ENTRYPOINT ["/app/docker/api-entrypoint.sh"]
CMD sh -c "uvicorn qdra.main:app --host 0.0.0.0 --port ${PORT:-8000}"
