# App
APP_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://qdra:qdra@localhost:5432/qdra

# Redis
REDIS_URL=redis://localhost:6379/0

# Worker
GRAPH_JOB_QUEUE=graph_reasoning_jobs
WORKER_CONCURRENCY=1

# CORS
CORS_ORIGINS=http://localhost:3000

# Migrations
RUN_MIGRATIONS_ON_STARTUP=false

# JWT
JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Image Storage
IMAGE_STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=./uploads
MAX_IMAGE_SIZE_MB=5
ALLOWED_IMAGE_MIME_TYPES=image/png,image/jpeg,image/webp

# S3 / MinIO
S3_BUCKET=
S3_REGION=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false

# Cache Configuration
L1_CACHING=False
L2_CACHING=True
CACHE_ENTITY_TTL=180000
CACHE_ENTITY_SIZE=1000
CACHE_RELATIONSHIP_TTL=180000
CACHE_RELATIONSHIP_SIZE=1000
CACHE_CONSTRAINT_TTL=180000
CACHE_CONSTRAINT_SIZE=1000
CACHE_PERMISSION_TTL=3600
CACHE_PERMISSION_SIZE=1000
CACHE_PERMISSION_PROJECT_SIZE=5000
