# Application Environment
APP_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/qdra

# Redis
REDIS_URL=redis://localhost:6379/0
GRAPH_JOB_QUEUE=graph_reasoning_jobs
WORKER_CONCURRENCY=1

# Cache Configuration
CACHE_ENTITY_LOCAL_SIZE=1000
CACHE_ENTITY_LOCAL_TTL=300
CACHE_ENTITY_REDIS_TTL=3600
CACHE_RELATIONSHIP_TTL=600
L1_CACHING=True
L2_CACHING=True

# Image Storage
IMAGE_STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=./uploads
MAX_IMAGE_SIZE_MB=5
ALLOWED_IMAGE_MIME_TYPES=image/png,image/jpeg,image/webp

# S3 Configuration (optional, for future use)
S3_BUCKET=
S3_REGION=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=False
